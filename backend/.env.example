APP_NAME=AI Travel Assistant API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
RATE_LIMIT_PER_MINUTE=40

ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1):\d+

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25

FAISAL_MOVERS_BASE_URL=https://faisalmovers.com
FAISAL_MOVERS_AJAX_PATH=/wp-admin/admin-ajax.php
FAISAL_MOVERS_TIMEOUT_SECONDS=25
